APP_ENV=development
DATABASE_URL=sqlite:///./interview_agent.db
UPLOAD_DIR=uploads
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Required for admin login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-password
AUTH_SECRET_KEY=replace-with-at-least-32-random-characters
AUTH_TOKEN_MINUTES=480
CANDIDATE_TOKEN_HOURS=24

# Optional LLM integration. Set LLM_PROVIDER to openai, azure_openai, claude, or mock.
# If omitted or set to mock, the backend uses deterministic fallback logic.
LLM_PROVIDER=mock
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AZURE_OPENAI_API_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=

# Legacy Claude-compatible option. Use LLM_PROVIDER=claude to enable it.
CLAUDE_API_URL=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-haiku
LLM_TIMEOUT_SECONDS=30

# 5 MiB by default.
MAX_RESUME_UPLOAD_BYTES=5242880
